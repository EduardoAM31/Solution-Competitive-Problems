void solve(){
    int n;
    cin >> n;
    queue<int> q;
    for(int i = 1;i <= n;i++){
        q.emplace(i);
    }
    while(!q.empty()){
        if(sz(q) == 1){
            cout << q.front() << endl;
            q.pop();
            continue;
        }
        q.emplace(q.front());
        q.pop();
        cout << q.front() << " ";
        q.pop();
    }
}
