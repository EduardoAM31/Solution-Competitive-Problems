void solve(){
    int n, m;
    cin >> n >> m;
    V<tuple<int,int,int>> g;
    for(int i = 0;i < m;i++){
        int u, v, p;
        cin >> u >> v >> p;
 
        g.emplace_back(u, v, p);
    }
    V<int> dist(n+1, inf), parent(n+1, -1);
    dist[1] = 0;
    int x = -1;
    for(int i = 0;i < n;i++){
        x = -1;
        for(auto [u, v, p] : g){
            if(dist[u] + p < dist[v]){
                dist[v] = dist[u] + p;
                parent[v] = u;
                x = u;
            }
        }
    }
    if(x == -1){
        cout << "NO\n";
        return;
    }
    cout << "YES\n";
    int y = x;
    for (int i = 0; i < n; ++i)
        y = parent[y];
 
    vector<int> path;
    for (int cur = y;; cur = parent[cur]) {
        path.push_back(cur);
        if (cur == y && path.size() > 1)
            break;
    }
    reverse(all(path));
    cout << path;
 
}
signed main() {
    ios;
    int tt=1;
    //cin>>tt;
    while(tt--){
        solve();
    }
    return 0;
}