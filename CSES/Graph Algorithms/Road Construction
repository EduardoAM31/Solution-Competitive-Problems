struct dsu{
    vector<int> id , sze;
    dsu(int n) : id(n), sze(n, 1) { iota (id. begin () , id.end () , 0); }
    int find (int a) { return a == id[a] ? a : id[a] = find (id[a]);}
    int unite (int a, int b) {
        a = find (a), b = find (b);
        if (a == b) return 0;
        if (sze[a] < sze[b]) swap (a, b);
        sze[a] += sze[b], id[b] = a;
        return 1;
    }
};
void solve(){
    int n,m;
    cin>>n>>m;
    int comp=n, maiorcomp=1;
    dsu a(n);
    while(m--){ 
        int u,v;cin>>u>>v;
        int tmp = a.unite(--u, --v);
        if(!tmp){
            cout<<comp<<" "<<maiorcomp<<endl;
        }else{
            maiorcomp = max(maiorcomp, a.sze[a.find(u)]);
            cout<<--comp<<" "<<maiorcomp<<endl;
        }
    }
}
