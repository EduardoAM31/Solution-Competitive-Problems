void solve(){
    int n, m;
    cin >> n >> m;
    V<V<int>> adj(n+1);
    for(int i=0;i<m;i++){
        int u, v;
        cin >> u >> v;
        adj[u].emplace_back(v);
    }
    V<int> dp(n+1, -1);
    function<int(int)> memo = [&](int u){
        if(u == n)return dp[n] = 1LL;
        if(dp[u] != -1)return dp[u];
        int ans = 0;
        for(auto& v : adj[u])
            ans = max(ans, memo(v) + 1);
        if(ans == 0)ans = -inf;
        return dp[u] = ans;
    };
    int aux = memo(1);
    if(dp[n] == -1){
        cout << "IMPOSSIBLE\n";
        return;
    }
    V<int> res;
    function<bool(int)> dfs = [&](int u){
        if(dp[u] == 1 && u != n)return false;
        bool ans = 0;
        if(u == n)ans = 1;
        for(auto& v : adj[u]){
            if(dp[v] + 1 == dp[u])
                ans = dfs(v);
            if(ans)
                break;
        }
        if(ans)res.emplace_back(u); 
        return ans;
    };
    dfs(1);
    reverse(all(res));
    cout << aux << endl;
    cout << res;
}
signed main() {
    ios;
    int tt=1;
    //cin>>tt;
    while(tt--){
        solve();
    }
    return 0;
}