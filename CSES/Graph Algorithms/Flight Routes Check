void solve(){
    int n, m;
    cin >> n >> m;
    V<V<int>> adjr(n+1), adj(n+1), comp;
    for(int i=0;i<m;i++){
        int x, y;
        cin >> x >> y;
        adjr[y].emplace_back(x);
        adj[x].emplace_back(y);
    }
    V<bool> vis(n+1, false);
    stack<int> ord;
    function<void(int)> dfs = [&](int u){
        vis[u] = 1;
        for(auto& v : adj[u])
            if(!vis[v])
                dfs(v);
        ord.emplace(u);
    };
    V<int> comp_;
    function<void(int)> dfs2 = [&](int u){
        vis[u] = 1;
        for(auto& v : adjr[u])
            if(!vis[v])
                dfs2(v);
        comp_.emplace_back(u);
    };
    for(int i=1;i<=n;i++)
        if(!vis[i])
            dfs(i);
    vis = V<bool>(n+1, false);
    V<int> raiz(n+1, 0);
    while(!ord.empty()){
        int u = ord.top();
        ord.pop();
        if(!vis[u]){
            dfs2(u);
            comp.emplace_back(comp_);
            int root = *min_element(all(comp_));
            for(auto& v : comp_){
                raiz[v] = root;
            }
            comp_.clear();
        }
    }
    V<V<int>> cond(n+1);
    for(int u=1;u<=n;u++){
        for(auto& v : adj[u]){
            if(raiz[v] != raiz[u]){
                cond[raiz[u]].emplace_back(raiz[v]);
            }
        }
    }
    for(int i=1;i<=n;i++){
        if(sz(cond[i])){
            cout << "NO\n";
            cout << cond[i][0] << " " << i << endl;
            return;
        }
    }
    int x = raiz[1];
    for(int i=2;i<=n;i++){
        if(raiz[i] != x){
            cout << "NO\n";
            cout << raiz[i] << " " << x << endl;
            return;
        }
    }
    cout << "YES\n";
 
}
