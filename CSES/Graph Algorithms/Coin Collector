const int MAX = 1e5+1;
int n;
vector<int> g[MAX], gi[MAX], adj[MAX]; // grafo invertido
int vis[MAX];
stack<int> S;
int comp[MAX]; // componente conexo de cada vertice
void dfs(int k) {
    vis[k] = 1;
	for (int i = 0; i < (int) g[k].size(); i++)
    if (!vis[g[k][i]]) dfs(g[k][i]);
    
	S.push(k);
}
 
void scc(int k, int c) {
	vis[k] = 1;
	comp[k] = c;
	for (int i = 0; i < (int) gi[k].size(); i++)
    if (!vis[gi[k][i]]) scc(gi[k][i], c);
}
 
void kosaraju() {
    for (int i = 0; i < n; i++) vis[i] = 0;
	for (int i = 0; i < n; i++) if (!vis[i]) dfs(i);
    
	for (int i = 0; i < n; i++) vis[i] = 0;
	while (S.size()) {
        int u = S.top();
		S.pop();
		if (!vis[u]) scc(u, u);
	}
}
V<int> tot;
void res(int u){
    vis[u] = 1;
    int ans = 0;
    for(auto& v : adj[u]){
        if(!vis[v]){
            res(v);
        }
        ans = max(ans, tot[v]);
    }
    tot[u] += ans;
}
void solve(){
    int m;
    cin >> n >> m;
    V<int> v(n);
    tot = V<int>(n, 0);
    cin >> v;
    for(int i=0;i<m;i++){
        int x, y;
        cin >> x >> y;
        --x, --y;
        gi[y].emplace_back(x);
        g[x].emplace_back(y);
    }
    kosaraju();
    for(int u = 0;u < n;u++){
        tot[comp[u]] += v[u];
        for(auto& v : g[u]){
            if(comp[u] != comp[v]){
                adj[comp[u]].emplace_back(comp[v]);
            }
        }
    }
    for (int i = 0; i < n; i++) vis[i] = 0;
    int ans = 0;
    for(int i = 0;i < n;i++){
        if(!vis[i])
            res(i);
    }
    cout << *max_element(all(tot)) << endl;
}
signed main() {
    ios;
