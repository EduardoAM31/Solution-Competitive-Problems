void solve(){
    int n;
    cin>>n;
    V<int> v(n);
    cin>>v;
    int sum=0;
    sort(all(v));
    for(auto& i : v)sum+=i;
    V<V<int>> dp(n+1, V<int>(sum+1, 0));
    dp[0][0] = 1;
    for(int i=1;i<=n;i++){
        for(int j=0;j<=sum;j++){
            dp[i][j] = dp[i-1][j];
            int sum = j - v[i-1];
            if(sum >= 0 && dp[i-1][sum])dp[i][j] = 1;
        }
    }
    int c = 0;
    V<int> res;
    for(int j=1;j<=sum;j++){
        if(dp[n][j]){
            c++;
            res.pb(j);
        }
    }
    cout<<c<<endl<<res;
}
signed main() {
    ios;
    int tt=1;
    //cin>>tt;
    while(tt--){
        solve();
    }
}