struct BIT{
    int n;
    V<int> bit, arr;
    
    BIT(int size) : n(size),  bit(n+1), arr(n) {}
 
    void set(int ind, int val) { update(ind, val - arr[ind]);}
 
    void update(int ind, int val) {
        arr[ind] += val;
        ind++;
        for(;ind <= n;ind += ind & -ind)bit[ind] += val;
    }
 
    int query(int ind) {
        int sum=0;
        ind++;
        for(;ind > 0; ind -= ind & -ind)sum += bit[ind];
        return sum;
    }
};
V<int> start;
V<int> End;
int timer=0;
void dfs(int u, int p, V<V<int>>& adj){
    start[u] = timer++;
    for(auto&v : adj[u]){
        if(v == p)continue;
        dfs(v, u, adj);
    }
    End[u] = timer;
}
void solve(){
    int n,qq;
    cin>>n>>qq;
    V<V<int>> adj(n);
    V<int> values(n);
    cin>>values;
    End = V<int>(n);
    start = V<int>(n);
    for(int i=0;i<n-1;i++){
        int u,v;
        cin>>u>>v;
        --u, --v;
        adj[u].pb(v);
        adj[v].pb(u);
    }
    dfs(0, -1, adj);
    BIT bit(n);
    for(int i=0;i<n;i++){
        bit.set(start[i], values[i]);
    }
    while(qq--){
        int t;
        cin>>t;
        if(t == 1){
            int u, x;
            cin>>u>>x;
            --u;
            bit.set(start[u], x);
        }else{
            int u;
            cin>>u;
            --u;
            cout<<bit.query(End[u]-1) - (start[u] == 0 ? 0 : bit.query(start[u]-1))<<endl;
        }
    }
}
