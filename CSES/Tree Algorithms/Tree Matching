const int maxn = 1e5 * 2;
vi sizes(maxn);
vvi adj(maxn);
int res=0;
void dfs(int u = 0,int p = -1){
    sizes[u] = 1;
    for(auto v : adj[u]){
        if(v == p)continue;
        dfs(v, u);
        if(sizes[v] == 1 && sizes[u] == 1){
            res++;
            sizes[u] = sizes[v] = 2;
        }
    }
}
void solve(){
    int n;
    cin>>n;
    for(int i=1;i<n;i++){
        int u,v;
        cin>>u>>v;
        --u,--v;
        adj[u].pb(v);
        adj[v].pb(u);
    }
    dfs();
    cout<<res<<endl;
}
signed main() {
    ios;
    int tt=1;
    //cin>>tt;
    while(tt--){
        solve();
    }
